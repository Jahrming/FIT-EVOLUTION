{
  "name": "fit-evolution360",
  "private": true,
  "packageManager": "npm@10.5.0",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:generate": "npm run prisma:generate -w api",
    "db:seed": "npm run prisma:seed -w api"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18"
  }
}
